    showView('pviewLoadingSubmit');
    var bar = document.getElementById('pLoadingBarSubmit');
    var msg = document.getElementById('pLoadingMsgSubmit');
    var i = 0; var steps = [[0,'Submitting application\u2026'],[100,'Submitting application\u2026']];
    function next() {
      if (i >= steps.length) { setTimeout(function(){ pGoToStep(5); }, 350); return; }
      bar.style.width = steps[i][0] + '%'; msg.textContent = steps[i][1]; i++;
      setTimeout(next, i === steps.length ? 400 : 200);
    }
    bar.style.width = '0%'; setTimeout(next, 80);
  }

  /* ===== PROPERTY — NAV ===== */
  function pGoToStep(n) {
    var map = {2:'pview2',3:'pview3',4:'pview4',5:'pview5'};
    showView(map[n] || 'pview2');
  }
  function pShowView(id) { showView(id); }
  function pRestartDemo() { restartDemo(); }

  /* ===== SHARED NAV ===== */
  function showView(id) {
    document.querySelectorAll('.step-view').forEach(function(v){ v.classList.remove('active'); });
    document.getElementById(id).classList.add('active');
    window.scrollTo({top:0, behavior:'smooth'});
  }

  /* ===== SHARED RESTART ===== */
  function restartDemo() {
    selectedPersona = null; jennyStartTime = null; kyleStartTime = null;
    selectedVehicles = new Set(['v1','v2']); customVehicleCount = 0; additionalDriverCount = 0;
    hmInsure = null; counters = {fullBath:3, halfBath:1, fireplace:0};
    garageOn = true; acOn = true; poolOn = false;
    document.getElementById('personaBtn').disabled = true;
    document.querySelectorAll('.persona-card:not(.coming-soon)').forEach(function(c){ c.classList.remove('selected'); });
    ['v1','v2'].forEach(function(id){
      var pw = document.getElementById('pvwrap-' + id); if (pw) pw.classList.add('selected');
      var tg = document.getElementById('toggle-' + id); if (tg) tg.classList.add('on');
      var dt = document.getElementById('details-' + id); if (dt) { dt.style.opacity=''; dt.style.pointerEvents=''; }
    });
    var cvc = document.getElementById('customVehiclesContainer'); if (cvc) cvc.innerHTML = '';
    var adc = document.getElementById('additionalDriversContainer'); if (adc) adc.innerHTML = '';
    updateVehSummary();
    var hmYes = document.getElementById('hmYes'); if (hmYes) hmYes.classList.remove('selected');
    var hmNo  = document.getElementById('hmNo');  if (hmNo)  hmNo.classList.remove('selected');
    var hmWarn = document.getElementById('hmWarn'); if (hmWarn) hmWarn.style.display = 'none';
    var detYes = document.getElementById('detYes'); if (detYes) detYes.classList.add('selected');
    var detNo  = document.getElementById('detNo');  if (detNo)  detNo.classList.remove('selected');
    var fbv = document.getElementById('fullBathVal'); if (fbv) fbv.textContent = '3';
    var hbv = document.getElementById('halfBathVal'); if (hbv) hbv.textContent = '1';
    var fpv = document.getElementById('fireplaceVal'); if (fpv) fpv.textContent = '0';
    var ftw = document.getElementById('fireplaceTypeWrap'); if (ftw) ftw.style.display = 'none';
    var gy = document.getElementById('garageYes'); if (gy) gy.classList.add('active');
    var gn = document.getElementById('garageNo');  if (gn) gn.classList.remove('active');
    var gtw = document.getElementById('garageTypeWrap'); if (gtw) gtw.style.display = 'block';
    var ay = document.getElementById('acYes'); if (ay) ay.classList.add('active');
    var an = document.getElementById('acNo');  if (an) an.classList.remove('active');
    var py = document.getElementById('poolYes'); if (py) py.classList.remove('active');
    var pn = document.getElementById('poolNo');  if (pn) pn.classList.add('active');
    ['gateFirst','gateLast','gateEmail'].forEach(function(id){
      var el = document.getElementById(id); if (el) { el.value = ''; el.classList.remove('error'); }
    });
    ['errFirst','errLast','gateErr'].forEach(function(id){
      var el = document.getElementById(id); if (el) el.textContent = '';
    });
    showView('view0');
  }

</script>
</body>
